{
  "source": "https://www.dayy.com/en",
  "color": {
    "brand": {
      "primary": "#10131b",
      "secondary": "#f2f2f2",
      "accent": "#ff7b2f"
    },
    "surface": {
      "background": "#ffffff",
      "soft": "#f3f3f3",
      "dark": "#10131b",
      "mist": "#eef1ef"
    },
    "text": {
      "primary": "#10131b",
      "secondary": "rgba(16, 19, 27, 0.56)",
      "muted": "rgba(16, 19, 27, 0.35)",
      "inverse": "#ffffff",
      "inverseMuted": "rgba(255, 255, 255, 0.58)"
    },
    "border": {
      "subtle": "rgba(16, 19, 27, 0.08)",
      "strong": "rgba(16, 19, 27, 0.18)"
    }
  },
  "typography": {
    "fontFamily": {
      "base": "system-ui, -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft YaHei', sans-serif",
      "mono": "ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace"
    },
    "fontSize": {
      "nav": "15px",
      "body": "18px",
      "lead": "clamp(28px, 4.2vw, 64px)",
      "display": "clamp(68px, 12vw, 176px)"
    },
    "fontWeight": {
      "regular": "400",
      "medium": "500",
      "bold": "800"
    },
    "lineHeight": {
      "tight": "0.92",
      "heading": "1.08",
      "body": "1.45"
    }
  },
  "spacing": {
    "pageX": "clamp(24px, 4.5vw, 64px)",
    "sectionY": "clamp(80px, 12vw, 176px)",
    "tile": "clamp(20px, 3vw, 44px)",
    "gap": "8px"
  },
  "radius": {
    "sm": "8px",
    "md": "12px",
    "pill": "999px"
  },
  "shadow": {
    "none": "none",
    "float": "0 12px 40px rgba(16, 19, 27, 0.08)"
  },
  "motion": {
    "duration": {
      "fast": "150ms",
      "normal": "300ms",
      "slow": "700ms"
    },
    "easing": {
      "standard": "cubic-bezier(0.4, 0, 0.2, 1)",
      "smooth": "cubic-bezier(0.455, 0.03, 0.515, 0.955)"
    }
  }
}
